# Kyros SaaS - Environment Configuration
# Copia este archivo a .env y edita los valores según tu configuración

# Base de Datos
DB_HOST=localhost
DB_NAME=kyros_saas
DB_USER=root
DB_PASS=

# Aplicación
APP_NAME=Kyros
APP_VERSION=1.0.0
APP_URL=http://localhost/eccomerce/kyros/
APP_DEBUG=true

# Sesión
SESSION_LIFETIME=604800
SESSION_SECURE=false
SESSION_HTTPONLY=true

# Email (para notificaciones futuras)
MAIL_DRIVER=smtp
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=
MAIL_PASS=

# WhatsApp Business API (futuro)
WHATSAPP_API_KEY=
WHATSAPP_PHONE_ID=

# Stripe (futuro)
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# Recaptcha (futuro)
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=

# Idioma
APP_LOCALE=es
TIMEZONE=America/New_York
