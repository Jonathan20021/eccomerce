<IfModule mod_rewrite.c>
    RewriteEngine On

    # Producción: forzar dominio canónico con HTTPS + www
    RewriteCond %{HTTP_HOST} ^store\.kyrosrd\.com$ [NC]
    RewriteRule ^ https://www.store.kyrosrd.com%{REQUEST_URI} [R=301,L]

    RewriteCond %{HTTP_HOST} ^www\.store\.kyrosrd\.com$ [NC]
    RewriteCond %{HTTPS} !=on
    RewriteRule ^ https://www.store.kyrosrd.com%{REQUEST_URI} [R=301,L]
    
    # No procesar archivos o directorios reales
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    
    # Reescribir todas las peticiones a index.php
    RewriteRule ^(.*)$ index.php [L,QSA]
</IfModule>

# Compresión GZIP
<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/json
</IfModule>

# Cache headers
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 year"
    ExpiresByType image/gif "access plus 1 year"
    ExpiresByType image/png "access plus 1 year"
    ExpiresByType text/css "access plus 1 year"
    ExpiresByType application/javascript "access plus 1 year"
    ExpiresByType application/x-javascript "access plus 1 year"
</IfModule>

# Only index.php is allowed to handle requests
<FilesMatch "^index\.php$">
    Allow from all
</FilesMatch>
